# Claude Code Authentication
# Copy this file to .env and fill in your credentials
# NEVER commit the .env file with real credentials

# ============================================================================
# IMPORTANT: CLI vs API Authentication
# ============================================================================
# - ANTHROPIC_API_KEY: Used for Python SDK and direct API calls
# - Claude CLI: Requires separate interactive login via 'claude auth login'
#   or '/login' command inside the CLI (uses account credentials, not API key)
#
# This .env file sets up environment variables for programmatic API usage.
# The CLI authentication is handled separately by the Claude Code application.
# ============================================================================

# Claude Code API Key
# Obtain from: https://console.anthropic.com/settings/keys
# Used by: Python SDK, direct API calls, scripts
CLAUDE_API_KEY=

# Claude Code Organization ID (optional)
# Obtain from: https://console.anthropic.com/settings/organization
CLAUDE_ORG_ID=

# Claude Code Email (for reference only)
# The email associated with your Claude account
# Note: CLI login uses account credentials, not this email directly
CLAUDE_EMAIL=

# Additional configuration (optional)
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MAX_TOKENS=8192
